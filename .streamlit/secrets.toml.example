# Copy this file to .streamlit/secrets.toml and fill in real values.
# In Streamlit Cloud, add these via Settings → Secrets (do NOT commit the real file).

# ── Google Drive file IDs for model weights ────────────────────────────────
# Right-click the file in Drive → Get link → copy the ID portion
# e.g. https://drive.google.com/file/d/<FILE_ID>/view
GDRIVE_CNN_ID   = ""   # ID for BEST_model.pth  (DenseNet201 by default)
GDRIVE_YOLO_ID  = ""   # ID for yolo_face_best.pt

# Override which backbone/filename the CNN ID points to (optional)
# CNN_FILENAME  = "densenet_best.pth"
# YOLO_FILENAME = "yolo_face_best.pt"
# MODEL_BACKBONE = "densenet"

# ── OpenAI key for VLM reasoning (optional) ───────────────────────────────
OPENAI_API_KEY = ""
